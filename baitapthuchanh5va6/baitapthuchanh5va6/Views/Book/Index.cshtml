@model IEnumerable<baitapthuchanh5.Models.Book>

@{
    ViewData["Title"] = "Danh sách sách";
}

<div class="container mt-4">
    <h2>Danh sách sách</h2>
    <a href="/Book/Create" class="btn btn-primary mb-3">Thêm sách mới</a>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tên sách</th>
                <th>Giá ($)</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td>@item.Price</td>
                    <td>
                        <a href="/Book/Detail/@item.Id" class="btn btn-sm btn-info">Chi tiết</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>